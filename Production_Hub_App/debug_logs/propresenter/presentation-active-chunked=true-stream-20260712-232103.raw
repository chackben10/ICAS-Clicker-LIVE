{"presentation":{"id":{"uuid":"45148F14-2804-4F51-9869-5D36D2E6602B","name":"91 - Aaradhikkunnu njangal aaradhikkunnu","index":213},"groups":[{"name":"","color":{"red":0.3999999761581421,"green":0.3999999761581421,"blue":0.3999999761581421,"alpha":1.0},"slides":[{"enabled":false,"notes":"","text":"","label":"A(minor).wav","size":{"width":1920,"height":1080}}],"uuid":"1299953A-E834-464A-AED3-929E864CB727"},{"name":"Chorus","color":{"red":0.800000011920929,"green":0.0,"blue":0.30588236451148987,"alpha":1.0},"slides":[{"enabled":true,"notes":"","text":"Aaradhikkunnu njangal aaradhikkunnu\naathmanathaneshuvine aaradhikkunnu\naaradhikkunnu njangal aaradhikkunnu\naathmavilum sathyathilum aaradhikkunnu\rആരാധിക്കുന്നു ഞങ്ങൾ ആരാധിക്കുന്നു\nആത്മനാഥനേശുവിനെ ആരാധിക്കുന്നു\nആരാധിക്കുന്നു ഞങ്ങൾ ആരാധിക്കുന്നു\nആത്മാവിലും സത്യത്തിലും ആരാധിക്കുന്നു","label":"","size":{"width":1920,"height":1080}}],"uuid":"2CF6A860-0BAD-43CB-9185-E8B139C5826D"},{"name":"Verse 1","color":{"red":0.0,"green":0.46666666865348816,"blue":0.800000011920929,"alpha":1.0},"slides":[{"enabled":true,"notes":"","text":"1 Hallelujah hallelujah geetham padidaam\nHallelujah geetham paadi aaradhichidam\r1 ഹല്ലേലുയ്യാ ഹല്ലേലുയ്യ ഗീതം പാടിടാം\nഹല്ലേലുയ്യാ ഗീതം പാടി ആരാധിച്ചിടാം","label":"","size":{"width":1920,"height":1080}}],"uuid":"B201FDF1-BDC3-4FA9-BABE-9902C8CD0441"},{"name":"Verse 2","color":{"red":0.0,"green":0.3490196168422699,"blue":0.6000000238418579,"alpha":1.0},"slides":[{"enabled":true,"notes":"","text":"2 aathma'nathhane njangal madhyathil vannu\naathmaavaal nirachiduka aaraadhikkuvaan\r2 ആത്മനാഥനേ ഞങ്ങൾ മദ്ധ്യത്തിൽ വന്നു\nആത്മാവാൽ നിറച്ചിടുക ആരാധിക്കുവാൻ","label":"","size":{"width":1920,"height":1080}}],"uuid":"7337BD18-DD4D-452C-8D7D-D4BC2D454F38"},{"name":"Verse 3","color":{"red":0.0,"green":0.23529411852359772,"blue":0.4000000059604645,"alpha":1.0},"slides":[{"enabled":true,"notes":"","text":"3 Innu njangal vishvasathal aaradhikunnu\nannu nathhan mukham-kandu aaradhichidum\r3 ഇന്നു ഞങ്ങൾ വിശ്വാസത്താൽ ആരാധിക്കുന്നു\nഅന്നു നാഥൻ മുഖംകണ്ടു ആരാധിച്ചിടും","label":"","size":{"width":1920,"height":1080}}],"uuid":"2A7F05DA-60EE-44AF-9D99-180057C2840A"},{"name":"Verse 4","color":{"red":0.0,"green":0.40784314274787903,"blue":0.7019608020782471,"alpha":1.0},"slides":[{"enabled":true,"notes":"","text":"4 Sarafukal aaradhikum parishudhane\nsanthoshathal svantha-makkal aaradhickunnu\r4 സാറാഫുകൾ ആരാധിക്കും പരിശുദ്ധനേ\nസന്തോഷത്താൽ സ്വന്തമക്കൾ ആരാധിക്കുന്നു","label":"","size":{"width":1920,"height":1080}}],"uuid":"9E06CB09-4285-46B0-AE0B-0C33DCE233D2"},{"name":"Verse 5","color":{"red":0.0,"green":0.29019609093666077,"blue":0.501960813999176,"alpha":1.0},"slides":[{"enabled":true,"notes":"","text":"5 bendnam-azhiyum kettukal azhiyum aaradhanayinkal\nbadakal ozhiyum kottakal thakarum aaradhanayinkal\r5 ബന്ധനമഴിയും കെട്ടുകൾ അഴിയും ആരാധനയിങ്കൽ\nബാധകൾ ഒഴിയും കോട്ടകൾ തകരും ആരാധനയിങ്കൽ","label":"","size":{"width":1920,"height":1080}}],"uuid":"4E2FE75C-3B0F-479E-B556-220D043B0E9B"},{"name":"Verse 6","color":{"red":0.0,"green":0.1764705926179886,"blue":0.3019607961177826,"alpha":1.0},"slides":[{"enabled":true,"notes":"","text":"6 rogam marum ksheenam marum aradhanayinkal\nmankudam udayum thee katheedum aradhanayinkal\r6 രോഗം മാറും ക്ഷീണം മാറും ആരാധനയിങ്കൽ\nമൺകുടം ഉടയും തീ കത്തീടും ആരാധനയിങ്കൽ","label":"","size":{"width":1920,"height":1080}}],"uuid":"AF446BE1-DCE2-4D76-A8AA-CCCE4A0BD396"},{"name":"Verse 7","color":{"red":0.0,"green":0.46666666865348816,"blue":0.800000011920929,"alpha":1.0},"slides":[{"enabled":true,"notes":"","text":"7 appostholar rathrikale aradhichapol\nchangala potti bendhi-tharellam mochitharayallo\r7 അപ്പോസ്തോലർ രാത്രികാലേ ആരാധിച്ചപ്പോൾ\nചങ്ങലപൊട്ടി ബന്ധിതരെല്ലാം മോചിതരായല്ലോ","label":"","size":{"width":1920,"height":1080}}],"uuid":"223C024A-E340-49F9-9A8C-89546CBFCF37"}],"has_timeline":false,"presentation_path":"/Users/icas/Documents/ProPresenter/Libraries/Malayalam Songs/91 - Aaradhikkunnu njangal aaradhikkunnu.pro","destination":"presentation","arrangements":[],"current_arrangement":"","type":"standard","is_authorized":true,"total_cues":9}}

